# =============================================================================
# Environment variables template
# Copy this file to .env and fill in your own values.
# Never commit the .env file (it is listed in .gitignore).
# =============================================================================

# S3 credentials for Switch SWITCHengines object storage (region ZH)
# Obtain these from: engines.switch.ch -> Project -> API Access -> View Credentials
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
ENDPOINT_URL="https://os.zhdk.cloud.switch.ch"

# Required to avoid checksum errors with this S3 backend
AWS_REQUEST_CHECKSUM_CALCULATION="when_required"
AWS_RESPONSE_CHECKSUM_VALIDATION="when_required"

DATADIR=/home/renku/work/s3-bucket/ACDC/
RESULTS_FOLDER=/home/renku/work/SDSC-arthur-project-1/results/0_tempo/
TEMPODATA_FOLDER=/home/renku/work/SDSC-arthur-project-1/tempodata/