# =============================================================================
# SECURITY - Never commit
# =============================================================================
.env
*.key
*.secret

# =============================================================================
# MEDICAL DATA - Never commit (too large + sensitive patient data)
# =============================================================================
*.nii
*.nii.gz
*.npy
*.tar.gz
*.zip

# =============================================================================
# TRAINED MODELS - Too large for a repository
# =============================================================================
*.pth
*.pt
*.joblib
*.pkl

# =============================================================================
# PROJECT-SPECIFIC FOLDERS
# =============================================================================
tempodata/
results/

# =============================================================================
# PYTHON - Auto-generated temporary files
# =============================================================================
__pycache__/
*.pyc
*.pyo
.venv/

# =============================================================================
# EDITORS AND TOOLS
# =============================================================================
.vscode/
.idea/
*.ipynb_checkpoints/
.DS_Store